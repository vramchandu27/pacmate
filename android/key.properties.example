# Copy this file to android/key.properties and fill in your real values.
# NEVER commit key.properties — it is in .gitignore.
#
# Generate a keystore with:
#   keytool -genkey -v -keystore pacmate-release.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 \
#     -alias pacmate
#
# Store the .jks file OUTSIDE the project directory (e.g., ~/keys/pacmate-release.jks)
# and reference its absolute path below.

storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=pacmate
storeFile=/absolute/path/to/pacmate-release.jks
